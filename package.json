{
  "name": "fluxtube",
  "version": "0.1.2",
  "private": true,
  "description": "Serverless sync between Miniflux and YouTube playlists.",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "eslint": "^10.5.0",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0"
  },
  "pnpm": {
    "overrides": {
      "esbuild": ">=0.28.1",
      "ws@>=8.0.0 <8.21.0": ">=8.21.0",
      "undici@>=7.23.0 <7.28.0": ">=7.28.0"
    }
  }
}
