---
/*
 * Live wrangler-tail terminal panel.
 *
 * Three parts vertically:
 * 1. Title bar — traffic-light dots, "wrangler tail · fluxtube-sync"
 *    label, "healthy" badge with green dot.
 * 2. Log body — 8 lines that type out sequentially via a small inlined
 *    script (counter cycles, fading each new line up). Trailing prompt
 *    line shows a steady green block cursor.
 * 3. Stat strip — four cells: next-tick countdown (MM:SS, amber, decremented
 *    every second), added today (+14, green), marked read (9), interval (30m).
 *
 * Log content is canned/illustrative — same shape as the real worker
 * output but not fetched. The wrangler-tail-as-product metaphor is the
 * point; this is a teaser, not a live tail.
 *
 * Reduced motion: JS check renders the full 8-line state immediately
 * and freezes the countdown at its starting value. The blinking cursor
 * is keyframed against the end state opacity:1 so it stays visible.
 */

const LINES = [
  ['14:30:00', 'tick', 'cron fired · 2 sync pairs'],
  ['14:30:00', 'pass1', 'fetch unread · category=tech'],
  ['14:30:01', 'pass1', '+playlistItems.insert vid=dQw4 → PL_tech'],
  ['14:30:01', 'd1', 'INSERT tracked row (id 218)'],
  ['14:30:02', 'pass2', 'reconcile · 7 tracked rows'],
  ['14:30:02', 'pass2', 'removed-by-user vid=8x9k → mark read'],
  ['14:30:03', 'd1', 'DELETE tracked row (id 204)'],
  ['14:30:03', 'ok', '+1 added · 1 read · 0 quota errors'],
] as const;
---

<section class="terminal" aria-label="example wrangler tail output">
  <header class="title-bar">
    <div class="dots" aria-hidden="true">
      <span class="dot dot-accent"></span>
      <span class="dot"></span>
      <span class="dot"></span>
    </div>
    <span class="title-label">wrangler tail · fluxtube-sync</span>
    <span class="health" aria-label="status: healthy">
      <span class="health-dot" aria-hidden="true"></span>healthy
    </span>
  </header>

  <ol class="log" data-log>
    {
      LINES.map(([ts, tag, text]) => (
        <li class="row" data-line>
          <span class="ts">{ts}</span>
          <span class={`tag tag-${tag}`}>{tag}</span>
          <span class="text">{text}</span>
        </li>
      ))
    }
    <li class="row prompt" aria-hidden="true">
      <span class="ts">14:30:04</span>
      <span class="caret">▌</span>
    </li>
  </ol>

  <div class="stats" aria-label="run statistics">
    <div class="cell">
      <span class="cell-label">next tick</span>
      <span class="cell-value cell-amber" data-countdown>29:47</span>
    </div>
    <div class="cell">
      <span class="cell-label">added today</span>
      <span class="cell-value cell-green">+14</span>
    </div>
    <div class="cell">
      <span class="cell-label">marked read</span>
      <span class="cell-value">9</span>
    </div>
    <div class="cell">
      <span class="cell-label">interval</span>
      <span class="cell-value">30m</span>
    </div>
  </div>
</section>

<style>
  .terminal {
    border: 1px solid var(--color-line-strong);
    border-radius: 5px;
    overflow: hidden;
    background: var(--color-bg-terminal);
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.4);
    margin-block-start: var(--space-8);
  }

  /* Title bar */

  .title-bar {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 14px;
    padding: 11px 15px;
    background: var(--color-bg-elevated);
    border-bottom: 1px solid var(--color-line);
    font-family: var(--font-mono);
    font-size: 11px;
  }

  .dots {
    display: flex;
    gap: 6px;
  }

  .dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--color-line-strong);
  }

  .dot-accent {
    background: var(--color-accent);
    opacity: 0.85;
  }

  .title-label {
    color: var(--color-fg-subtle);
    letter-spacing: 0.04em;
  }

  .health {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--color-fg-subtle);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 10px;
  }

  .health-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--color-green);
  }

  /* Log body */

  .log {
    list-style: none;
    margin: 0;
    padding: 18px;
    font-family: var(--font-mono);
    font-size: 12.5px;
    line-height: 1.85;
    min-height: 230px;
    max-width: none;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .row {
    display: grid;
    grid-template-columns: auto auto 1fr;
    gap: 14px;
    white-space: pre;
    align-items: baseline;
    margin: 0;
  }

  .row[data-line] {
    opacity: 0;
    transform: translateY(2px);
    transition:
      opacity 0.28s ease,
      transform 0.28s ease;
  }

  .row[data-line].is-visible {
    opacity: 1;
    transform: none;
  }

  .ts {
    color: #5a5347;
  }

  .tag {
    min-width: 46px;
    font-weight: 500;
  }

  .tag-tick {
    color: var(--color-amber);
  }
  .tag-pass1,
  .tag-pass2 {
    color: var(--color-accent);
  }
  .tag-d1 {
    color: var(--color-fg-muted);
  }
  .tag-ok {
    color: var(--color-green);
  }

  .text {
    color: #bdb39f;
  }

  .prompt {
    grid-template-columns: auto 1fr;
    margin-top: 6px;
  }

  .caret {
    color: var(--color-green);
    line-height: 1;
    animation: caret-blink 1.1s steps(1) infinite;
  }

  /* Stat strip */

  .stats {
    display: flex;
    flex-wrap: wrap;
    border-top: 1px solid var(--color-line);
    background: var(--color-bg-elevated);
  }

  .cell {
    flex: 1 1 120px;
    min-width: 120px;
    padding: 14px 18px;
    border-right: 1px solid var(--color-line);
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .cell:last-child {
    border-right: 0;
  }

  .cell-label {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-fg-subtle);
  }

  .cell-value {
    font-family: var(--font-mono);
    font-size: 20px;
    font-weight: 500;
    color: var(--color-fg);
    font-variant-numeric: tabular-nums;
  }

  .cell-amber {
    color: var(--color-amber);
  }
  .cell-green {
    color: var(--color-green);
  }

  @media (max-width: 540px) {
    .title-bar {
      grid-template-columns: auto 1fr;
    }
    .health {
      grid-column: 1 / -1;
      justify-content: flex-end;
    }
    .log {
      font-size: 11.5px;
      padding: 14px;
    }
    .row {
      gap: 10px;
    }
  }
</style>

<script>
  /*
   * Log type-in + countdown timer. Both cosmetic; both honor
   * prefers-reduced-motion by rendering the final state and
   * skipping the loop.
   */

  const PREFERS_REDUCED = matchMedia('(prefers-reduced-motion: reduce)').matches;

  document.querySelectorAll<HTMLOListElement>('[data-log]').forEach((log) => {
    const lines = Array.from(log.querySelectorAll<HTMLLIElement>('[data-line]'));
    if (PREFERS_REDUCED) {
      lines.forEach((li) => li.classList.add('is-visible'));
      return;
    }

    const REVEAL_STEP = 820;
    const FULL_HOLD = 2200;

    let i = 0;
    const reveal = () => {
      if (i < lines.length) {
        lines[i].classList.add('is-visible');
        i += 1;
        setTimeout(reveal, REVEAL_STEP);
        return;
      }
      // All lines shown — hold, then reset and replay.
      setTimeout(() => {
        lines.forEach((li) => li.classList.remove('is-visible'));
        i = 0;
        setTimeout(reveal, 400);
      }, FULL_HOLD);
    };
    setTimeout(reveal, 200);
  });

  /*
   * Countdown: starts at 1787 seconds (29:47), decrements every 1s,
   * wraps to 1799 (29:59) when it reaches 0. Cosmetic continuation
   * of the "tick" rhythm in the logs.
   */
  document.querySelectorAll<HTMLElement>('[data-countdown]').forEach((el) => {
    if (PREFERS_REDUCED) return;
    let secs = 1787;
    const tick = () => {
      secs = secs <= 0 ? 1799 : secs - 1;
      const m = Math.floor(secs / 60)
        .toString()
        .padStart(2, '0');
      const s = (secs % 60).toString().padStart(2, '0');
      el.textContent = `${m}:${s}`;
    };
    setInterval(tick, 1000);
  });
</script>
