---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Not Found" description="That page doesn't exist on fluxtube.forklabs.cc.">
  <main>
    <div class="container narrow">
      <p class="label">404</p>
      <h1>Not here.</h1>
      <p class="muted">
        That path doesn't match any page on this site. Maybe you wanted
        <a href="/">the FluxTube landing</a>, or
        <a href="https://forklabs.cc">forklabs.cc</a> for the other projects.
      </p>
    </div>
  </main>
</BaseLayout>

<style>
  .narrow {
    padding-block: var(--space-24);
    max-width: 520px;
  }

  h1 {
    margin-block-start: var(--space-3);
  }
</style>
