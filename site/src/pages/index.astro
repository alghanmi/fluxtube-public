---
import BaseLayout from '../layouts/BaseLayout.astro';
import LogoChip from '../components/LogoChip.astro';
import SyncedStamp from '../components/SyncedStamp.astro';
import Terminal from '../components/Terminal.astro';

const version = '0.2.0';
---

<BaseLayout
  title="FluxTube"
  description="Sync unread YouTube entries from Miniflux into YouTube playlists. Mark them read when you've watched and removed them. Public source; deploy your own."
>
  <main>
    <div class="container">
      <div class="manhead">
        <span class="manhead-left">fluxtube(1)</span>
        <span class="manhead-center">User Commands</span>
        <span class="manhead-right">fluxtube(1)</span>
      </div>

      <header class="hero">
        <div class="hero-head">
          <LogoChip />
          <p class="eyebrow">Name</p>
        </div>
        <h1 class="hero-title">FluxTube</h1>
        <p class="hero-lead">
          A serverless sync job that bridges <em>Miniflux</em> with YouTube playlists. Reads unread RSS
          entries from your Miniflux categories on a cron tick, adds them to mapped playlists, and marks
          them read after you watch and remove them on YouTube.
        </p>
        <div class="stamp-slot" aria-hidden="true">
          <SyncedStamp />
        </div>
      </header>

      <Terminal />

      <section aria-labelledby="description-h" class="section">
        <h2 id="description-h" class="manh2">Description</h2>
        <p class="section-lead">
          One run, two passes. <em>Pass 1 only adds. Pass 2 only removes.</em> Each pass is idempotent
          — re-running mid-failure is safe.
        </p>
        <div class="pass-grid">
          <article class="pass pass-1">
            <h3 class="pass-label">Pass 1 · insert</h3>
            <p class="pass-body">
              For each unread Miniflux entry whose URL points at a YouTube video, call
              <code>playlistItems.insert</code> on the mapped playlist and write a tracked-row to D1.
              The D1 row keeps a per-entry ledger so Pass 2 knows what's already on the playlist.
            </p>
          </article>
          <article class="pass pass-2">
            <h3 class="pass-label">Pass 2 · reconcile</h3>
            <p class="pass-body">
              For each row in D1, ask YouTube whether the video is still on the playlist. If
              <em>you removed the video</em> (watched and dismissed), mark the Miniflux entry read and
              delete the D1 row. No video deletion is ever issued from this side.
            </p>
          </article>
        </div>
      </section>

      <section aria-labelledby="config-h" class="section">
        <h2 id="config-h" class="manh2">Configuration</h2>
        <p class="section-lead">
          One file. A list of <em>category → playlist</em> pairs. Reload by re-deploying the Worker.
        </p>
        <pre
          class="config-pre"><span class="cfg-comment"># category → playlist pairs (toml)</span>
<span class="cfg-key">[[sync]]</span>
category  = <span class="cfg-string">"tech"</span>
playlist  = <span class="cfg-string">"PL_tech_watch_later"</span>
<span class="cfg-key">[[sync]]</span>
category  = <span class="cfg-string">"cycling"</span>
playlist  = <span class="cfg-string">"PL_rides"</span></pre>
      </section>

      <section aria-labelledby="observability-h" class="section">
        <h2 id="observability-h" class="manh2">Observability</h2>
        <p class="section-lead">
          A silent process needs loud logs. Four surfaces, layered: console, dead-man's-switch,
          structured shipping, metrics.
        </p>
        <div class="obs-grid">
          <div class="obs-cell">
            <h3 class="obs-title">stdout JSON</h3>
            <p class="obs-sub">always on · wrangler tail</p>
          </div>
          <div class="obs-cell">
            <h3 class="obs-title">Healthchecks.io</h3>
            <p class="obs-sub">cron dead-man's switch</p>
          </div>
          <div class="obs-cell">
            <h3 class="obs-title">Grafana Loki</h3>
            <p class="obs-sub">structured log shipping</p>
          </div>
          <div class="obs-cell">
            <h3 class="obs-title">Grafana OTLP</h3>
            <p class="obs-sub">11 gauges per run</p>
          </div>
        </div>
      </section>

      <section aria-labelledby="see-also-h" class="section see-also">
        <h2 id="see-also-h" class="manh2">See also</h2>
        <ul class="see-list" role="list">
          <li>
            <a href="https://github.com/alghanmi/fluxtube">github.com/alghanmi/fluxtube</a>
            <span class="see-note subtle">source · MIT license · self-host the whole thing</span>
          </li>
          <li>
            <a href="https://github.com/alghanmi/fluxtube/blob/main/TODO.md">TODO.md</a>
            <span class="see-note subtle">bootstrap walk-through, about an evening end-to-end</span>
          </li>
          <li>
            <a href="https://miniflux.app">miniflux.app</a>
            <span class="see-note subtle">the RSS reader fluxtube reads from</span>
          </li>
          <li>
            <a href="/privacy">/privacy</a>
            <span class="see-note subtle">what data fluxtube touches (very little)</span>
          </li>
          <li>
            <a href="/terms">/terms</a>
            <span class="see-note subtle">MIT, you self-host, no warranty</span>
          </li>
        </ul>
      </section>

      <footer class="site-foot">
        <span class="site-foot-left">fluxtube.forklabs.cc</span>
        <span class="site-foot-center">© 2026 · v{version}</span>
        <a class="site-foot-right" href="https://forklabs.cc">↖ forklabs(7)</a>
      </footer>
    </div>
  </main>
</BaseLayout>

<style>
  /* ── Hero ──────────────────────────────────────────────────────────────── */

  .hero {
    padding-block: 64px 36px;
    position: relative;
    animation: hero-fade-up 0.5s ease both;
  }

  .hero-head {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 22px;
  }

  .eyebrow {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin: 0;
    max-width: none;
  }

  .hero-title {
    font-family: var(--font-display);
    font-weight: 340;
    font-size: clamp(2.8rem, 8vw, 4.8rem);
    line-height: 1;
    letter-spacing: -0.03em;
    color: var(--color-fg);
    font-variation-settings:
      'SOFT' 100,
      'WONK' 0,
      'opsz' 144;
    margin: 0;
  }

  .hero-lead {
    margin-top: 22px;
    max-width: 38rem;
    font-size: 16px;
    line-height: 1.6;
    color: var(--color-fg-muted);
  }

  .stamp-slot {
    position: absolute;
    top: 40px;
    right: 4px;
  }

  @media (max-width: 640px) {
    .stamp-slot {
      position: static;
      margin-top: 24px;
    }
  }

  /* ── Sections ──────────────────────────────────────────────────────────── */

  .section {
    margin-top: var(--space-12);
  }

  .section-lead {
    margin-top: var(--space-4);
    color: var(--color-fg-muted);
    max-width: 38rem;
    line-height: 1.6;
  }

  /* ── Description / pass cards ──────────────────────────────────────────── */

  .pass-grid {
    margin-top: var(--space-6);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 18px;
  }

  @media (max-width: 640px) {
    .pass-grid {
      grid-template-columns: 1fr;
    }
  }

  .pass {
    border: 1px solid var(--color-line);
    border-left-width: 2px;
    border-radius: 3px;
    background: var(--color-bg-elevated);
    padding: 22px;
  }

  .pass-1 {
    border-left-color: var(--color-accent);
  }

  .pass-2 {
    border-left-color: var(--color-green);
  }

  .pass-label {
    font-family: var(--font-mono);
    font-size: var(--size-xs);
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    margin: 0 0 var(--space-3);
  }

  .pass-1 .pass-label {
    color: var(--color-accent);
  }

  .pass-2 .pass-label {
    color: var(--color-green);
  }

  .pass-body {
    margin: 0;
    color: var(--color-fg-muted);
    line-height: 1.65;
    max-width: none;
  }

  .pass-body code {
    color: var(--color-green);
  }

  /* ── Configuration TOML ────────────────────────────────────────────────── */

  .config-pre {
    margin-top: var(--space-6);
    font-family: var(--font-mono);
    font-size: 12.5px;
    color: var(--color-fg-muted);
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-line);
    border-radius: 4px;
    padding: 20px 22px;
    line-height: 1.8;
    overflow-x: auto;
    white-space: pre;
  }

  .cfg-comment {
    color: var(--color-fg-subtle);
  }
  .cfg-key {
    color: var(--color-amber);
  }
  .cfg-string {
    color: var(--color-green);
  }

  /* ── Observability grid ────────────────────────────────────────────────── */

  .obs-grid {
    margin-top: var(--space-6);
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: 12px;
  }

  .obs-cell {
    border: 1px solid var(--color-line);
    border-radius: 3px;
    padding: 15px 16px;
    background: var(--color-bg-elevated);
  }

  .obs-title {
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 500;
    color: var(--color-fg);
    margin: 0;
    letter-spacing: 0.01em;
  }

  .obs-sub {
    margin: 4px 0 0;
    font-size: 11px;
    color: var(--color-fg-subtle);
    max-width: none;
  }

  /* ── See also ──────────────────────────────────────────────────────────── */

  .see-also {
    padding-block-end: var(--space-8);
  }

  .see-list {
    list-style: none;
    padding: 0;
    margin: var(--space-6) 0 0;
    display: grid;
    grid-template-columns: max-content 1fr;
    gap: var(--space-2) var(--space-6);
    font-family: var(--font-mono);
    font-size: var(--size-sm);
    max-width: none;
  }

  .see-list li {
    display: contents;
    margin: 0;
  }

  .see-list li > a {
    color: var(--color-fg);
    text-decoration: underline;
    text-decoration-color: var(--color-line-strong);
    text-underline-offset: 0.18em;
  }

  .see-list li > a:hover {
    color: var(--color-accent);
    text-decoration-color: var(--color-accent);
  }

  .see-note {
    font-size: var(--size-xs);
    align-self: center;
  }

  @media (max-width: 540px) {
    .see-list {
      grid-template-columns: 1fr;
      gap: var(--space-3);
    }
    .see-list li {
      display: flex;
      flex-direction: column;
      gap: var(--space-1);
    }
  }

  /* ── Footer ────────────────────────────────────────────────────────────── */

  .site-foot {
    margin-top: 80px;
    padding-block: 18px 56px;
    border-top: 1px solid var(--color-line);
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: baseline;
    gap: var(--space-4);
    font-family: var(--font-mono);
    font-size: 11.5px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-fg-subtle);
  }

  .site-foot-left {
    text-align: left;
  }

  .site-foot-center {
    text-align: center;
    color: var(--color-fg-muted);
  }

  .site-foot-right {
    text-align: right;
    color: var(--color-fg-subtle);
    text-decoration: none;
    transition: color var(--transition);
  }

  .site-foot-right:hover {
    color: var(--color-accent);
  }

  @media (max-width: 540px) {
    .site-foot {
      grid-template-columns: 1fr;
      gap: 6px;
      text-align: center;
    }
    .site-foot-left,
    .site-foot-right {
      text-align: center;
    }
  }
</style>
