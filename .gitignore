# ── Node ──────────────────────────────────────────────────────────────────────
node_modules/
*.log
npm-debug.log*
pnpm-debug.log*
.pnpm-store/

# Build artifacts
dist/
build/
.astro/
.tsbuildinfo
*.tsbuildinfo

# Coverage
coverage/
.nyc_output/

# ── Wrangler / Cloudflare Workers ─────────────────────────────────────────────
.wrangler/
.dev.vars
.dev.vars.*
!.dev.vars.example

# ── Terraform ─────────────────────────────────────────────────────────────────
.terraform/
.terraform.lock.hcl
# `*.tfstate*` catches the canonical names AND any manually-suffixed backup
# (e.g. `pre-v5-state.tfstate-2.bak` from a provider-migration session).
*.tfstate*
crash.log
crash.*.log

# Local tfvars: never commit. Example is committed.
*.tfvars
*.tfvars.json
!*.tfvars.example

# Local backend config: generated by fluxtube-deploy/scripts/bootstrap-local-tf.sh.
# Contains R2 access keys + bucket/key. Example is committed.
backend.hcl
!backend.hcl.example

# Terraform plan output
*.tfplan

# ── Editors / OS ──────────────────────────────────────────────────────────────
.DS_Store
.idea/
.vscode/
*.swp
*.swo
*~

# ── Env ───────────────────────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Bitwarden / local credentials ─────────────────────────────────────────────
client_secret*.json
*-credentials.json

# ── Claude Code local state ───────────────────────────────────────────────────
.claude/
